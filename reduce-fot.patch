new file mode 100644
index 0000000..0ceca67
--- /dev/null
+++ b/src/pages/libri/pagina/[page].astro
@@ -0,0 +1,64 @@
+---
+import BaseLayout from '~/layouts/BaseLayout.astro';
+import BooksCatalogSection from '~/components/BooksCatalogSection';
+import { executeQuery } from '~/lib/datocms/executeQuery';
+import { toPlainText } from '~/lib/text';
+import { withFallbackSeo } from '~/lib/seo';
+import { mapBooksToCards } from '~/lib/books';
+import { BOOKS_PAGE_QUERY, BOOKS_PER_PAGE, type BooksPageQueryResult } from '../index/_graphql';
+import DraftModeQueryListener from '~/components/DraftModeQueryListener';
+import { resolveDraftMode } from '~/lib/draftPreview';
+
+const rawPage = Astro.params.page ?? '';
+
+// Only positive integers without leading zeros are valid page tokens. Page 1 is
+// canonical at /libri, so redirect it there instead of serving a duplicate.
+if (!/^[1-9][0-9]*$/.test(rawPage)) {
+  return new Response('Not found', { status: 404 });
+}
+
+const currentPage = Number.parseInt(rawPage, 10);
+if (currentPage === 1) {
+  return Astro.redirect('/libri', 301);
+}
+
+const draftModeEnabled = resolveDraftMode(Astro);
+const variables = { first: BOOKS_PER_PAGE, skip: (currentPage - 1) * BOOKS_PER_PAGE };
+
+const data = await executeQuery<BooksPageQueryResult>(BOOKS_PAGE_QUERY, {
+  includeDrafts: draftModeEnabled,
+  variables,
+});
+
+const total = data._allBooksMeta?.count ?? 0;
+const totalPages = Math.max(1, Math.ceil(total / BOOKS_PER_PAGE));
+
+// Out-of-range pages must not return a 200 with an empty grid (bad for SEO and
+// confusing for users); serve a real 404 instead.
+if (currentPage > totalPages) {
+  return new Response('Not found', { status: 404 });
+}
+
+const booksIndexContent = data.booksIndexPage?.[0] ?? null;
+const heroSection = {
+  title: booksIndexContent?.title?.trim() || 'Libri',
+  subtitleHtml: booksIndexContent?.subtitle?.trim() || null,
+};
+const seo = withFallbackSeo(booksIndexContent?._seoMetaTags, {
+  title: `${heroSection.title} — pagina ${currentPage}`,
+  description: heroSection.subtitleHtml ? toPlainText(heroSection.subtitleHtml) : undefined,
+});
+
+const books = mapBooksToCards(data.allBooks ?? []);
+---
+
+<BaseLayout seo={seo}>
+  <BooksCatalogSection
+    title={heroSection.title}
+    subtitleHtml={heroSection.subtitleHtml}
+    books={books}
+    currentPage={currentPage}
+    totalPages={totalPages}
+  />
+  <DraftModeQueryListener query={BOOKS_PAGE_QUERY} variables={variables} />
+</BaseLayout>

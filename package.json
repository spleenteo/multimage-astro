{
  "name": "MM Astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "sync-datocms": "node scripts/sync-datocms.mjs",
    "dev": "npm run sync-datocms && astro dev",
    "docs:inventory": "node scripts/check-docs-inventory.mjs",
    "start": "npm run sync-datocms && astro dev",
    "bundle-search-client": "node scripts/build-search-client.mjs",
    "prebuild": "npm run bundle-search-client",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate-schema": "npx datocms schema:generate schema.ts",
    "format": "npx prettier --write --ignore-path .prettierignore .",
    "test": "npm run format && npm run lint && npm run build",
    "lint": "prettier --check --ignore-path .prettierignore ."
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/vercel": "^10.0.7",
    "@datocms/astro": "^0.6.12",
    "@datocms/cda-client": "^0.2.10",
    "@datocms/cma-client": "^5.4.18",
    "@datocms/content-link": "^0.3.20",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "astro": "^6.3.3",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "jsonwebtoken": "^9.0.3",
    "postcss": "^8.5.14",
    "serialize-error": "^13.0.1",
    "swiper": "^12.1.4",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@astrojs/ts-plugin": "^1.10.8",
    "@types/jsdom": "^28.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "datocms": "^4.0.28",
    "dotenv-cli": "^11.0.0",
    "esbuild": "^0.28.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1"
  }
}

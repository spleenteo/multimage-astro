{
  "name": "MM Astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "sync-datocms": "node scripts/sync-datocms.mjs",
    "dev": "npm run sync-datocms && astro dev",
    "docs:inventory": "node scripts/check-docs-inventory.mjs",
    "start": "npm run sync-datocms && astro dev",
    "bundle-search-client": "node scripts/build-search-client.mjs",
    "prebuild": "npm run bundle-search-client",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate-schema": "npx datocms schema:generate schema.ts",
    "format": "npx prettier --write --ignore-path .prettierignore .",
    "test": "npm run format && npm run lint &&SERVER=static npm run build && SERVER=preview npm run build",
    "lint": "prettier --check --ignore-path .prettierignore ."
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/tailwind": "^6.0.2",
    "@datocms/astro": "^0.6.12",
    "@datocms/cda-client": "^0.2.10",
    "@datocms/cma-client": "^4.0.2",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "astro": "^5.18.1",
    "autoprefixer": "^10.5.0",
    "datocms": "^4.0.27",
    "jsdom": "^27.4.0",
    "jsonwebtoken": "^9.0.3",
    "postcss": "^8.5.14",
    "serialize-error": "^12.0.0",
    "swiper": "^11.2.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@astrojs/ts-plugin": "^1.10.8",
    "@astrojs/vercel": "^8.2.11",
    "@types/jsdom": "^27.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "dotenv-cli": "^7.4.4",
    "esbuild": "^0.25.12",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1"
  }
}

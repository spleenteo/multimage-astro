DATOCMS_PUBLISHED_CONTENT_CDA_TOKEN=
DATOCMS_DRAFT_CONTENT_CDA_TOKEN=
SECRET_API_TOKEN=
SIGNED_COOKIE_JWT_SECRET=
DRAFT_MODE_COOKIE_NAME=multimage_draft_mode
PUBLIC_DATOCMS_SITE_SEARCH_API_TOKEN=
PUBLIC_SITE_URL=

# Required on Vercel — opaque token used both as:
# - __prerender_bypass cookie value (draft mode → CDN bypass)
# - x-prerender-revalidate header (on-demand ISR via /api/revalidate)
# Generate with: `openssl rand -hex 32`
BYPASS_TOKEN=

# Optional: enables click-to-edit overlay (Visual Editing) in draft mode.
# Use the BARE admin URL with NO /environments/... suffix when editing the
# primary environment, e.g. https://multimage.admin.datocms.com
# Appending /environments/main makes edit-URLs take the sandbox shape and the
# Web Previews plugin reports "Environment Mismatch Detected".
DATOCMS_BASE_EDITING_URL=

# Optional: required only when running `npm run generate-schema`
DATOCMS_CMA_TOKEN=

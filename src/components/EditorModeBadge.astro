---
// Floating indicator shown only while the editor session is active (i.e. draft
// mode is on). It reminds the editor they are seeing unpublished content, gives
// quick access to the staff tools, and a one-click exit. Rendered by
// BaseLayout; the printable book sheet has no layout and so no badge.
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const exitHref = `/api/draft-mode/disable?url=${encodeURIComponent(currentPath)}`;
---

<aside
  class="fixed bottom-4 left-4 z-50 flex items-center gap-3 rounded-full border border-brand-navy/20 bg-white/95 px-4 py-2 text-sm shadow-lg backdrop-blur print:hidden"
  aria-label="Modalità editor"
>
  <span class="flex items-center gap-2 font-semibold text-brand-navy">
    <span class="h-2 w-2 rounded-full bg-brand-sky" aria-hidden="true"></span>
    Modalità editor
  </span>
  <a href="/staff" class="text-brand-sky underline-offset-2 hover:underline">Strumenti staff</a>
  <a href={exitHref} class="text-brand-charcoal/70 underline-offset-2 hover:underline">Esci</a>
</aside>

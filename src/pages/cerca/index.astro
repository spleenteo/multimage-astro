---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { withFallbackSeo } from '~/lib/seo';
import './_search.css';

export { prerender } from '~/lib/prerender';

const MIN_QUERY_LENGTH = 3;
const SITE_SEARCH_ENDPOINT = 'https://site-api.datocms.com/search-results';

const siteSearchToken = import.meta.env.PUBLIC_DATOCMS_SITE_SEARCH_API_TOKEN;

if (!siteSearchToken) {
  throw new Error(
    'La variabile PUBLIC_DATOCMS_SITE_SEARCH_API_TOKEN è obbligatoria per la pagina di ricerca.',
  );
}

const searchConfig = {
  endpoint: SITE_SEARCH_ENDPOINT,
  token: siteSearchToken,
  minQueryLength: MIN_QUERY_LENGTH,
  limit: 25,
  fuzzy: true,
};

const searchScriptSrc = import.meta.env.DEV
  ? '/src/pages/cerca/search-page.client.ts'
  : '/generated/search-page.client.js';

const seo = withFallbackSeo([], {
  title: 'Cerca | Multimage',
  description:
    'Cerca libri, autrici e autori, articoli del magazine e tutte le risorse del sito Multimage interrogando direttamente l\u2019indice di DatoCMS.',
});
---

<BaseLayout seo={seo}>
  <section class="search-page">
    <div
      class="container search-page__container"
      data-search-root
      data-endpoint={searchConfig.endpoint}
      data-token={searchConfig.token}
      data-min-length={String(searchConfig.minQueryLength)}
      data-limit={String(searchConfig.limit)}
      data-fuzzy={searchConfig.fuzzy ? 'true' : 'false'}
    >
      <header class="search-page__intro">
        <h1 class="search-page__title">Cerca nel catalogo Multimage</h1>
        <p class="search-page__subtitle">
          Digita almeno {MIN_QUERY_LENGTH} caratteri per avviare la ricerca. I risultati vengono aggiornati
          in tempo reale senza ricaricare la pagina.
        </p>
      </header>

      <form class="search-page__form" role="search" method="get" action="/cerca" data-search-form>
        <label class="search-page__label" for="search-query">
          <span class="sr-only">Cerca libri, autori o articoli</span>
          <input
            id="search-query"
            name="q"
            type="search"
            autocomplete="off"
            inputmode="search"
            placeholder="Titoli, autori, parole chiave…"
            aria-describedby="search-status"
            class="search-page__input"
            data-search-input
          />
        </label>
        <button type="submit" class="search-page__submit">Cerca</button>
      </form>

      <p
        class="search-page__status"
        id="search-status"
        role="status"
        aria-live="polite"
        data-search-status
      >
        Inserisci almeno {MIN_QUERY_LENGTH} caratteri per iniziare.
      </p>

      <div class="search-filters" data-search-filters>
        <span class="search-filters__label">Filtra per:</span>
        <label class="search-filters__item">
          <input type="checkbox" value="books" data-search-filter />
          <iconify-icon icon="iconoir:book" width="16" height="16" aria-hidden="true"
          ></iconify-icon>
          <span>Libri</span>
        </label>
        <label class="search-filters__item">
          <input type="checkbox" value="authors" data-search-filter />
          <iconify-icon icon="iconoir:user-badge-check" width="16" height="16" aria-hidden="true"
          ></iconify-icon>
          <span>Autori</span>
        </label>
        <label class="search-filters__item">
          <input type="checkbox" value="info" data-search-filter />
          <iconify-icon icon="iconoir:post" width="16" height="16" aria-hidden="true"
          ></iconify-icon>
          <span>Informazioni</span>
        </label>
        <label class="search-filters__item">
          <input type="checkbox" value="exact" data-search-exact />
          <iconify-icon icon="iconoir:lock" width="16" height="16" aria-hidden="true"
          ></iconify-icon>
          <span>Ricerca esatta</span>
        </label>
      </div>

      <div class="search-results" data-search-results hidden>
        <ul class="search-results__list" data-search-list></ul>
      </div>
    </div>
  </section>

  <script type="module" src={searchScriptSrc} is:inline></script>
</BaseLayout>
